# Copie este arquivo para ".env" e ajuste os valores

# Banco de dados PostgreSQL (Neon em produção)
DATABASE_URL=postgresql://neondb_owner:senha@ep-xxx.sa-east-1.aws.neon.tech/neondb?sslmode=require

# Porta da API (Vercel ignora isso em produção)
PORT=4000

# Segredo usado para assinar os tokens JWT
# IMPORTANTE: troque por um valor longo e aleatório
JWT_SECRET=troque-este-valor-por-uma-string-aleatoria-longa-e-secreta

# Tempo de validade do token de usuário
JWT_EXPIRES_IN=8h

# URL do frontend (usada para CORS)
FRONTEND_URL=https://finovo-xi.vercel.app
