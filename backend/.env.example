# Copie este arquivo para ".env" e ajuste os valores

# Banco de dados PostgreSQL
DATABASE_URL=postgresql://finovo:finovo123@localhost:5432/finovo

# Porta da API
PORT=4000

# Segredo usado para assinar os tokens JWT (login)
# IMPORTANTE: troque por um valor longo e aleatório antes de usar em produção
JWT_SECRET=troque-este-valor-por-uma-string-aleatoria-longa-e-secreta

# Tempo de validade do token de login
JWT_EXPIRES_IN=7d

# URL do frontend (usada para CORS)
FRONTEND_URL=http://localhost:5173
